{
  "name": "@talk-to-a-folder/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "node --env-file-if-exists=.env ../../node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start": "node --env-file-if-exists=.env dist/main",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "eslint \"{src,test}/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@talk-to-a-folder/shared": "workspace:*",
    "chromadb": "^3.3.2",
    "google-auth-library": "^10.6.1",
    "googleapis": "^171.4.0",
    "groq-sdk": "^0.37.0",
    "llamaindex": "^0.12.1",
    "openai": "^6.27.0",
    "pdf-parse": "^2.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.5",
    "typescript": "^5.5.0"
  }
}
